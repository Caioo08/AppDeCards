<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpacedRepetitionApp.Views.StudyPage"
             Title="Revisão">

    <NavigationPage.BarBackgroundColor>
        <Color>#0A0A0F</Color>
    </NavigationPage.BarBackgroundColor>

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0A0A0F" Offset="0.0"/>
            <GradientStop Color="#0D1117" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="24,20,24,40" Spacing="20">

            <!-- ── CARD DA PERGUNTA ───────────────────── -->
            <Border BackgroundColor="#0F1623"
                    StrokeShape="RoundRectangle 24"
                    Stroke="#1A2233"
                    StrokeThickness="1"
                    Padding="28,32"
                    MinimumHeightRequest="200">
                <VerticalStackLayout Spacing="16" VerticalOptions="Center">

                    <Label Text="PERGUNTA"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="#2D3748"
                           CharacterSpacing="2.5"/>

                    <Label Text="{Binding PerguntaAtual}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#E2E8F0"
                           LineBreakMode="WordWrap"
                           LineHeight="1.4"/>

                </VerticalStackLayout>
            </Border>

            <!-- ── CARD DA RESPOSTA ───────────────────── -->
            <Border BackgroundColor="#0A1A12"
                    StrokeShape="RoundRectangle 24"
                    Stroke="#00E5A030"
                    StrokeThickness="1"
                    Padding="28,28"
                    IsVisible="{Binding MostrarResposta}"
                    MinimumHeightRequest="120">
                <VerticalStackLayout Spacing="12">

                    <Label Text="RESPOSTA"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="#00E5A0"
                           CharacterSpacing="2.5"/>

                    <Label Text="{Binding RespostaAtual}"
                           FontSize="18"
                           TextColor="#86EFAC"
                           LineBreakMode="WordWrap"
                           LineHeight="1.4"/>

                </VerticalStackLayout>
            </Border>

            <!-- ── BOTÃO VER RESPOSTA ─────────────────── -->
            <Border BackgroundColor="#00E5A0"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    IsVisible="{Binding NaoMostrarResposta}"
                    Padding="0">
                <Button Text="Revelar Resposta"
                        Command="{Binding MostrarRespostaCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#0A0A0F"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="56"
                        BorderWidth="0"/>
            </Border>

            <!-- ── LABEL "COMO FOI?" ──────────────────── -->
            <Label Text="Como foi?"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="#2D3748"
                   CharacterSpacing="1"
                   HorizontalOptions="Center"
                   IsVisible="{Binding MostrarResposta}"/>

            <!-- ── BOTÕES DE AVALIAÇÃO 2×2 ────────────── -->
            <Grid ColumnDefinitions="*,10,*"
                  RowDefinitions="Auto,10,Auto"
                  IsVisible="{Binding MostrarResposta}">

                <!-- Errei -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="#1A0A0A"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#3D1515"
                        StrokeThickness="1"
                        Padding="0">
                    <Button Text="✗   Errei"
                            Command="{Binding ResponderCommand}"
                            CommandParameter="0"
                            BackgroundColor="Transparent"
                            TextColor="#FC8181"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="56"
                            BorderWidth="0"/>
                </Border>

                <!-- Difícil -->
                <Border Grid.Row="0" Grid.Column="2"
                        BackgroundColor="#1A1100"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#3D2D00"
                        StrokeThickness="1"
                        Padding="0">
                    <Button Text="◐  Difícil"
                            Command="{Binding ResponderCommand}"
                            CommandParameter="3"
                            BackgroundColor="Transparent"
                            TextColor="#F6AD55"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="56"
                            BorderWidth="0"/>
                </Border>

                <!-- Médio -->
                <Border Grid.Row="2" Grid.Column="0"
                        BackgroundColor="#0A0F1A"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#152040"
                        StrokeThickness="1"
                        Padding="0">
                    <Button Text="◑  Médio"
                            Command="{Binding ResponderCommand}"
                            CommandParameter="4"
                            BackgroundColor="Transparent"
                            TextColor="#63B3ED"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="56"
                            BorderWidth="0"/>
                </Border>

                <!-- Fácil -->
                <Border Grid.Row="2" Grid.Column="2"
                        BackgroundColor="#0A1A12"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#153D25"
                        StrokeThickness="1"
                        Padding="0">
                    <Button Text="✓   Fácil"
                            Command="{Binding ResponderCommand}"
                            CommandParameter="5"
                            BackgroundColor="Transparent"
                            TextColor="#68D391"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="56"
                            BorderWidth="0"/>
                </Border>

            </Grid>

            <!-- ── SESSÃO CONCLUÍDA ────────────────────── -->
            <VerticalStackLayout IsVisible="{Binding SessaoConcluida}"
                                 Spacing="16"
                                 Margin="0,20,0,0">

                <Label Text="🎉"
                       FontSize="56"
                       HorizontalOptions="Center"/>

                <Label Text="Sessão concluída!"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#E2E8F0"
                       HorizontalOptions="Center"/>

                <Label Text="Você revisou todos os cards de hoje."
                       FontSize="14"
                       TextColor="#4A5568"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <Border BackgroundColor="#00E5A0"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        Margin="0,8,0,0"
                        Padding="0">
                    <Button Text="Voltar"
                            Clicked="OnVoltarClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0A0A0F"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="56"
                            BorderWidth="0"/>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
