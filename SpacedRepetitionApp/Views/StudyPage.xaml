<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpacedRepetitionApp.Views.StudyPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#1C1917">

    <Grid RowDefinitions="Auto,3,*">

        <!-- ══ HEADER CUSTOMIZADO COM BOTÃO VOLTAR ══════════════════════ -->
        <Grid Grid.Row="0"
              Padding="20,52,20,16"
              ColumnDefinitions="Auto,*,Auto">

            <Border Grid.Column="0"
                    BackgroundColor="#292524"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#44403C" StrokeThickness="1"
                    Padding="0" VerticalOptions="Center">
                <Button Text="←"
                        Clicked="OnVoltarClicked"
                        BackgroundColor="Transparent"
                        TextColor="#A8A29E"
                        FontSize="18"
                        WidthRequest="44" HeightRequest="40"
                        BorderWidth="0"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center">
                <Label Text="{Binding ModoTexto}"
                       FontSize="9" FontAttributes="Bold"
                       TextColor="#78716C" CharacterSpacing="2"
                       HorizontalOptions="Center"/>
                <Label Text="{Binding Progresso}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#F5F5F4"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Espaço para simetria -->
            <BoxView Grid.Column="2" WidthRequest="44"/>

        </Grid>

        <!-- Barra de progresso -->
        <ProgressBar Grid.Row="1"
                     Progress="{Binding ProgressoValor}"
                     ProgressColor="#F59E0B"
                     HeightRequest="3" Margin="0"
                     VerticalOptions="Start"/>

        <!-- ══ CONTEÚDO ════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,16,20,40" Spacing="14">

                <!-- SEM CARDS -->
                <VerticalStackLayout IsVisible="{Binding SemCards}"
                                     Spacing="14" Margin="0,60,0,0">
                    <Label Text="✦" FontSize="44"
                           TextColor="#44403C"
                           HorizontalOptions="Center"/>
                    <Label Text="Nenhum card para revisar"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="#E7E5E4"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Todos os cards estão em dia."
                           FontSize="14" TextColor="#78716C"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Border BackgroundColor="#292524"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#44403C" StrokeThickness="1"
                            Padding="0" Margin="0,8,0,0">
                        <Button Text="Voltar"
                                Clicked="OnVoltarClicked"
                                BackgroundColor="Transparent"
                                TextColor="#A8A29E"
                                FontAttributes="Bold" FontSize="15"
                                HeightRequest="50" BorderWidth="0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- EM ANDAMENTO -->
                <VerticalStackLayout IsVisible="{Binding EmAndamento}" Spacing="14">

                    <!-- Card da PERGUNTA -->
                    <Border BackgroundColor="#292524"
                            StrokeShape="RoundRectangle 22"
                            Stroke="#44403C" StrokeThickness="1"
                            Padding="24,28"
                            MinimumHeightRequest="200">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="PERGUNTA"
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="#57534E" CharacterSpacing="3"/>
                            <Label Text="{Binding PerguntaAtual}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#F5F5F4"
                                   LineBreakMode="WordWrap"
                                   LineHeight="1.45"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Card da RESPOSTA (após revelar) -->
                    <Border IsVisible="{Binding MostrarResposta}"
                            BackgroundColor="#1A1208"
                            StrokeShape="RoundRectangle 22"
                            Stroke="#78350F" StrokeThickness="1"
                            Padding="24,22">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="RESPOSTA"
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="#F59E0B" CharacterSpacing="3"/>
                            <Label Text="{Binding RespostaAtual}"
                                   FontSize="18"
                                   TextColor="#FCD34D"
                                   LineBreakMode="WordWrap"
                                   LineHeight="1.45"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Botão REVELAR -->
                    <Border IsVisible="{Binding NaoMostrarResposta}"
                            BackgroundColor="#F59E0B"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0" Padding="0">
                        <Button Text="Revelar Resposta"
                                Command="{Binding MostrarRespostaCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#1C1917"
                                FontAttributes="Bold" FontSize="16"
                                HeightRequest="56" BorderWidth="0"/>
                    </Border>

                    <!-- Label avaliação -->
                    <Label Text="COMO FOI?"
                           FontSize="9" FontAttributes="Bold"
                           TextColor="#57534E" CharacterSpacing="2.5"
                           HorizontalOptions="Center"
                           IsVisible="{Binding MostrarResposta}"
                           Margin="0,2,0,0"/>

                    <!-- Botões 2×2 com preview -->
                    <Grid ColumnDefinitions="*,8,*"
                          RowDefinitions="Auto,8,Auto"
                          IsVisible="{Binding MostrarResposta}">

                        <!-- Errei -->
                        <Border Grid.Row="0" Grid.Column="0"
                                BackgroundColor="#1F0808"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#3B0E0E" StrokeThickness="1"
                                Padding="0">
                            <Button Text="{Binding PreviewErrei}"
                                    Command="{Binding ResponderCommand}"
                                    CommandParameter="0"
                                    BackgroundColor="Transparent"
                                    TextColor="#FCA5A5"
                                    FontAttributes="Bold" FontSize="12"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="64" BorderWidth="0"/>
                        </Border>

                        <!-- Difícil -->
                        <Border Grid.Row="0" Grid.Column="2"
                                BackgroundColor="#1F1208"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#3B2008" StrokeThickness="1"
                                Padding="0">
                            <Button Text="{Binding PreviewDificil}"
                                    Command="{Binding ResponderCommand}"
                                    CommandParameter="3"
                                    BackgroundColor="Transparent"
                                    TextColor="#FCD34D"
                                    FontAttributes="Bold" FontSize="12"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="64" BorderWidth="0"/>
                        </Border>

                        <!-- Médio -->
                        <Border Grid.Row="2" Grid.Column="0"
                                BackgroundColor="#080E1F"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#0E1A3B" StrokeThickness="1"
                                Padding="0">
                            <Button Text="{Binding PreviewMedio}"
                                    Command="{Binding ResponderCommand}"
                                    CommandParameter="4"
                                    BackgroundColor="Transparent"
                                    TextColor="#93C5FD"
                                    FontAttributes="Bold" FontSize="12"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="64" BorderWidth="0"/>
                        </Border>

                        <!-- Fácil -->
                        <Border Grid.Row="2" Grid.Column="2"
                                BackgroundColor="#081F10"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#0E3B1A" StrokeThickness="1"
                                Padding="0">
                            <Button Text="{Binding PreviewFacil}"
                                    Command="{Binding ResponderCommand}"
                                    CommandParameter="5"
                                    BackgroundColor="Transparent"
                                    TextColor="#86EFAC"
                                    FontAttributes="Bold" FontSize="12"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="64" BorderWidth="0"/>
                        </Border>

                    </Grid>

                </VerticalStackLayout>

                <!-- SESSÃO CONCLUÍDA -->
                <VerticalStackLayout IsVisible="{Binding SessaoConcluida}"
                                     Spacing="16" Margin="0,20,0,0">

                    <Label Text="✦" FontSize="52"
                           TextColor="#F59E0B"
                           HorizontalOptions="Center"/>

                    <Label Text="Sessão concluída"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="#F5F5F4"
                           HorizontalOptions="Center"/>

                    <!-- 3 métricas -->
                    <Grid ColumnDefinitions="*,6,*,6,*" Margin="0,8,0,0">

                        <Border Grid.Column="0"
                                BackgroundColor="#292524"
                                StrokeShape="RoundRectangle 14"
                                Stroke="#44403C" StrokeThickness="1"
                                Padding="10,14">
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding TotalSessao}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="#F5F5F4"
                                       HorizontalOptions="Center"/>
                                <Label Text="cards"
                                       FontSize="11" TextColor="#78716C"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                BackgroundColor="#1A1208"
                                StrokeShape="RoundRectangle 14"
                                Stroke="#78350F" StrokeThickness="1"
                                Padding="10,14">
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding TaxaAcertoTexto}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="#F59E0B"
                                       HorizontalOptions="Center"/>
                                <Label Text="acerto"
                                       FontSize="11" TextColor="#78716C"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="4"
                                BackgroundColor="#292524"
                                StrokeShape="RoundRectangle 14"
                                Stroke="#44403C" StrokeThickness="1"
                                Padding="10,14">
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding AcertosSessao}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="#86EFAC"
                                       HorizontalOptions="Center"/>
                                <Label Text="acertos"
                                       FontSize="11" TextColor="#78716C"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <Border BackgroundColor="#F59E0B"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            Margin="0,8,0,0" Padding="0">
                        <Button Text="Estudar de Novo"
                                Command="{Binding ReiniciarCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#1C1917"
                                FontAttributes="Bold" FontSize="16"
                                HeightRequest="56" BorderWidth="0"/>
                    </Border>

                    <Border BackgroundColor="#292524"
                            StrokeShape="RoundRectangle 18"
                            Stroke="#44403C" StrokeThickness="1"
                            Padding="0">
                        <Button Text="Voltar para Home"
                                Clicked="OnVoltarClicked"
                                BackgroundColor="Transparent"
                                TextColor="#78716C"
                                FontAttributes="Bold" FontSize="15"
                                HeightRequest="50" BorderWidth="0"/>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
