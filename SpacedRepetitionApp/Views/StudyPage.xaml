<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpacedRepetitionApp.Views.StudyPage"
             Title="Revisão">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0A0A0F" Offset="0.0"/>
            <GradientStop Color="#0D1117" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="4,*">

        <!-- Barra de progresso -->
        <ProgressBar Grid.Row="0" Progress="{Binding ProgressoValor}"
                     ProgressColor="#00E5A0" HeightRequest="4"
                     Margin="0" VerticalOptions="Start"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,16,24,40" Spacing="16">

                <!-- SEM CARDS -->
                <VerticalStackLayout IsVisible="{Binding SemCards}"
                                     Spacing="14" Margin="0,80,0,0">
                    <Label Text="—" FontSize="48" TextColor="#2D3748"
                           HorizontalOptions="Center"/>
                    <Label Text="Nenhum card disponível"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="#E2E8F0" HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Button Text="Voltar" Clicked="OnVoltarClicked"
                            BackgroundColor="#0F1623" TextColor="#E2E8F0"
                            CornerRadius="14" HeightRequest="50"
                            BorderColor="#1A2233" BorderWidth="1"
                            FontAttributes="Bold" Margin="0,12,0,0"/>
                </VerticalStackLayout>

                <!-- EM ANDAMENTO -->
                <VerticalStackLayout IsVisible="{Binding EmAndamento}" Spacing="16">

                    <!-- Progresso + modo -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding ModoTexto}"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#2D3748" CharacterSpacing="1"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding Progresso}"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#00E5A0" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Card da PERGUNTA -->
                    <Border BackgroundColor="#0F1623"
                            StrokeShape="RoundRectangle 20"
                            Stroke="#1A2233" StrokeThickness="1"
                            Padding="28,28" MinimumHeightRequest="180">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="PERGUNTA" FontSize="10" FontAttributes="Bold"
                                   TextColor="#2D3748" CharacterSpacing="2.5"/>
                            <Label Text="{Binding PerguntaAtual}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#E2E8F0"
                                   LineBreakMode="WordWrap" LineHeight="1.4"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Card da RESPOSTA (revelada) -->
                    <Border IsVisible="{Binding MostrarResposta}"
                            BackgroundColor="#0A1A12"
                            StrokeShape="RoundRectangle 20"
                            Stroke="#153D25" StrokeThickness="1"
                            Padding="28,24">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="RESPOSTA" FontSize="10" FontAttributes="Bold"
                                   TextColor="#00E5A0" CharacterSpacing="2.5"/>
                            <Label Text="{Binding RespostaAtual}"
                                   FontSize="18" TextColor="#86EFAC"
                                   LineBreakMode="WordWrap" LineHeight="1.4"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Botão REVELAR -->
                    <Border IsVisible="{Binding NaoMostrarResposta}"
                            BackgroundColor="#00E5A0"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0" Padding="0">
                        <Button Text="Revelar Resposta"
                                Command="{Binding MostrarRespostaCommand}"
                                BackgroundColor="Transparent" TextColor="#0A0A0F"
                                FontAttributes="Bold" FontSize="16"
                                HeightRequest="56" BorderWidth="0"/>
                    </Border>

                    <!-- Label avaliação -->
                    <Label Text="COMO FOI?" FontSize="10" FontAttributes="Bold"
                           TextColor="#2D3748" CharacterSpacing="2"
                           HorizontalOptions="Center"
                           IsVisible="{Binding MostrarResposta}"/>

                    <!-- BOTÕES 2×2 com preview de intervalo -->
                    <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,10,Auto"
                          IsVisible="{Binding MostrarResposta}">

                        <Border Grid.Row="0" Grid.Column="0"
                                BackgroundColor="#1A0A0A" StrokeShape="RoundRectangle 14"
                                Stroke="#3D1515" StrokeThickness="1" Padding="0">
                            <Button Text="{Binding PreviewErrei}"
                                    Command="{Binding ResponderCommand}" CommandParameter="0"
                                    BackgroundColor="Transparent" TextColor="#FC8181"
                                    FontAttributes="Bold" FontSize="13"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="60" BorderWidth="0"/>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2"
                                BackgroundColor="#1A1100" StrokeShape="RoundRectangle 14"
                                Stroke="#3D2D00" StrokeThickness="1" Padding="0">
                            <Button Text="{Binding PreviewDificil}"
                                    Command="{Binding ResponderCommand}" CommandParameter="3"
                                    BackgroundColor="Transparent" TextColor="#F6AD55"
                                    FontAttributes="Bold" FontSize="13"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="60" BorderWidth="0"/>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0"
                                BackgroundColor="#0A0F1A" StrokeShape="RoundRectangle 14"
                                Stroke="#152040" StrokeThickness="1" Padding="0">
                            <Button Text="{Binding PreviewMedio}"
                                    Command="{Binding ResponderCommand}" CommandParameter="4"
                                    BackgroundColor="Transparent" TextColor="#63B3ED"
                                    FontAttributes="Bold" FontSize="13"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="60" BorderWidth="0"/>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2"
                                BackgroundColor="#0A1A12" StrokeShape="RoundRectangle 14"
                                Stroke="#153D25" StrokeThickness="1" Padding="0">
                            <Button Text="{Binding PreviewFacil}"
                                    Command="{Binding ResponderCommand}" CommandParameter="5"
                                    BackgroundColor="Transparent" TextColor="#68D391"
                                    FontAttributes="Bold" FontSize="13"
                                    LineBreakMode="WordWrap"
                                    HeightRequest="60" BorderWidth="0"/>
                        </Border>

                    </Grid>

                </VerticalStackLayout>

                <!-- SESSÃO CONCLUÍDA -->
                <VerticalStackLayout IsVisible="{Binding SessaoConcluida}"
                                     Spacing="16" Margin="0,24,0,0">

                    <Label Text="🎉" FontSize="64" HorizontalOptions="Center"/>

                    <Label Text="Sessão concluída!"
                           FontSize="28" FontAttributes="Bold" TextColor="#E2E8F0"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                    <!-- Resultado -->
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Border Grid.Column="0" BackgroundColor="#0F1623"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#1A2233" StrokeThickness="1" Padding="18,16">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="{Binding TotalSessao}"
                                       FontSize="32" FontAttributes="Bold"
                                       TextColor="#E2E8F0" HorizontalOptions="Center"/>
                                <Label Text="revisados" FontSize="12"
                                       TextColor="#4A5568" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#0A1A12"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#153D25" StrokeThickness="1" Padding="18,16">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="{Binding TaxaAcertoTexto}"
                                       FontSize="32" FontAttributes="Bold"
                                       TextColor="#68D391" HorizontalOptions="Center"/>
                                <Label Text="de acerto" FontSize="12"
                                       TextColor="#4A5568" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="#00E5A0" StrokeShape="RoundRectangle 16"
                            StrokeThickness="0" Margin="0,8,0,0" Padding="0">
                        <Button Text="Estudar de Novo"
                                Command="{Binding ReiniciarCommand}"
                                BackgroundColor="Transparent" TextColor="#0A0A0F"
                                FontAttributes="Bold" FontSize="16"
                                HeightRequest="56" BorderWidth="0"/>
                    </Border>

                    <Border BackgroundColor="#0F1623" StrokeShape="RoundRectangle 16"
                            Stroke="#1A2233" StrokeThickness="1" Padding="0">
                        <Button Text="Voltar para Home"
                                Clicked="OnVoltarClicked"
                                BackgroundColor="Transparent" TextColor="#9996A8"
                                FontAttributes="Bold" FontSize="15"
                                HeightRequest="52" BorderWidth="0"/>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
