<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpacedRepetitionApp.Views.EditCardPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#1C1917">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER COM BOTÃO VOLTAR -->
        <Grid Grid.Row="0"
              Padding="20,52,20,16"
              ColumnDefinitions="Auto,*">

            <Border Grid.Column="0"
                    BackgroundColor="#292524"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#44403C" StrokeThickness="1"
                    Padding="0" VerticalOptions="Center">
                <Button Text="←"
                        Clicked="OnCancelarClicked"
                        BackgroundColor="Transparent"
                        TextColor="#A8A29E"
                        FontSize="18"
                        WidthRequest="44" HeightRequest="40"
                        BorderWidth="0"/>
            </Border>

            <Label Grid.Column="1"
                   Text="Editar Card"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="#F5F5F4"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

        </Grid>

        <!-- CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,8,24,40" Spacing="0">

                <Label Text="Altere a pergunta ou a resposta"
                       FontSize="13" TextColor="#78716C"
                       Margin="0,0,0,28"/>

                <Label Text="PERGUNTA"
                       FontSize="9" FontAttributes="Bold"
                       TextColor="#57534E" CharacterSpacing="3"
                       Margin="0,0,0,8"/>
                <Border BackgroundColor="#292524"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#44403C" StrokeThickness="1"
                        Padding="16,0" Margin="0,0,0,20">
                    <Entry x:Name="PerguntaEntry"
                           PlaceholderColor="#44403C"
                           TextColor="#F5F5F4"
                           BackgroundColor="Transparent"
                           FontSize="15" HeightRequest="52"/>
                </Border>

                <Label Text="RESPOSTA"
                       FontSize="9" FontAttributes="Bold"
                       TextColor="#57534E" CharacterSpacing="3"
                       Margin="0,0,0,8"/>
                <Border BackgroundColor="#292524"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#44403C" StrokeThickness="1"
                        Padding="16,0" Margin="0,0,0,36">
                    <Entry x:Name="RespostaEntry"
                           PlaceholderColor="#44403C"
                           TextColor="#F5F5F4"
                           BackgroundColor="Transparent"
                           FontSize="15" HeightRequest="52"/>
                </Border>

                <Border BackgroundColor="#F59E0B"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        Margin="0,0,0,10" Padding="0">
                    <Button Text="Salvar Alterações"
                            Clicked="OnSaveClicked"
                            BackgroundColor="Transparent"
                            TextColor="#1C1917"
                            FontAttributes="Bold" FontSize="16"
                            HeightRequest="56" BorderWidth="0"/>
                </Border>

                <Border BackgroundColor="#292524"
                        StrokeShape="RoundRectangle 18"
                        Stroke="#44403C" StrokeThickness="1"
                        Padding="0">
                    <Button Text="Cancelar"
                            Clicked="OnCancelarClicked"
                            BackgroundColor="Transparent"
                            TextColor="#78716C"
                            FontAttributes="Bold" FontSize="15"
                            HeightRequest="48" BorderWidth="0"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
