<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpacedRepetitionApp.Views.EditCardPage"
             Title="Editar Card">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0A0A0F" Offset="0.0"/>
            <GradientStop Color="#0D1117" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,40" Spacing="0">

            <Label Text="Editar Card" FontSize="30" FontAttributes="Bold"
                   TextColor="#E2E8F0" Margin="0,0,0,4"/>
            <Label Text="Altere a pergunta ou a resposta"
                   FontSize="13" TextColor="#4A5568" Margin="0,0,0,32"/>

            <Label Text="PERGUNTA" FontSize="10" FontAttributes="Bold"
                   TextColor="#2D3748" CharacterSpacing="2" Margin="0,0,0,10"/>
            <Border BackgroundColor="#0F1623" StrokeShape="RoundRectangle 16"
                    Stroke="#1A2233" StrokeThickness="1"
                    Padding="18,4" Margin="0,0,0,24">
                <Entry x:Name="PerguntaEntry"
                       PlaceholderColor="#2D3748" TextColor="#E2E8F0"
                       BackgroundColor="Transparent" FontSize="15" HeightRequest="52"/>
            </Border>

            <Label Text="RESPOSTA" FontSize="10" FontAttributes="Bold"
                   TextColor="#2D3748" CharacterSpacing="2" Margin="0,0,0,10"/>
            <Border BackgroundColor="#0F1623" StrokeShape="RoundRectangle 16"
                    Stroke="#1A2233" StrokeThickness="1"
                    Padding="18,4" Margin="0,0,0,36">
                <Entry x:Name="RespostaEntry"
                       PlaceholderColor="#2D3748" TextColor="#E2E8F0"
                       BackgroundColor="Transparent" FontSize="15" HeightRequest="52"/>
            </Border>

            <Border BackgroundColor="#00E5A0" StrokeShape="RoundRectangle 16"
                    StrokeThickness="0" Margin="0,0,0,12" Padding="0">
                <Button Text="Salvar Alterações" Clicked="OnSaveClicked"
                        BackgroundColor="Transparent" TextColor="#0A0A0F"
                        FontAttributes="Bold" FontSize="16"
                        HeightRequest="56" BorderWidth="0"/>
            </Border>

            <Border BackgroundColor="#0F1623" StrokeShape="RoundRectangle 16"
                    Stroke="#1A2233" StrokeThickness="1" Padding="0">
                <Button Text="Cancelar" Clicked="OnCancelarClicked"
                        BackgroundColor="Transparent" TextColor="#9996A8"
                        FontAttributes="Bold" FontSize="15"
                        HeightRequest="50" BorderWidth="0"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
