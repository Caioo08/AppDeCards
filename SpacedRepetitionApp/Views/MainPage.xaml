<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpacedRepetitionApp.MainPage"
             Title=""
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0A0A0F" Offset="0.0"/>
            <GradientStop Color="#0D1117" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── HEADER ─────────────────────────────── -->
            <Grid Padding="28,60,28,32" ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="6">
                    <Label Text="memo"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="#00E5A0"
                           CharacterSpacing="-1"/>
                    <Label Text="seus flashcards"
                           FontSize="13"
                           TextColor="#4A5568"/>
                </VerticalStackLayout>

                <!-- Pill de total de cards -->
                <Border Grid.Column="1"
                        VerticalOptions="Center"
                        BackgroundColor="#131920"
                        StrokeShape="RoundRectangle 20"
                        Stroke="#1E2D3D"
                        StrokeThickness="1"
                        Padding="14,8">
                    <Label Text="{Binding Cards.Count, StringFormat='{0} cards'}"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#00E5A0"/>
                </Border>

            </Grid>

            <!-- ── BOTÕES DE AÇÃO ─────────────────────── -->
            <Grid Padding="28,0,28,32"
                  ColumnDefinitions="*,12,*">

                <!-- Adicionar Card -->
                <Border Grid.Column="0"
                        BackgroundColor="#00E5A0"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        Padding="0">
                    <Button Text="＋  Novo Card"
                            Clicked="OnAddCardClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0A0A0F"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="54"
                            BorderWidth="0"/>
                </Border>

                <!-- Estudar -->
                <Border Grid.Column="2"
                        BackgroundColor="#131920"
                        StrokeShape="RoundRectangle 18"
                        Stroke="#1E2D3D"
                        StrokeThickness="1"
                        Padding="0">
                    <Button Text="▶  Estudar"
                            Clicked="OnStudyClicked"
                            BackgroundColor="Transparent"
                            TextColor="#00E5A0"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="54"
                            BorderWidth="0"/>
                </Border>

            </Grid>

            <!-- ── SEPARADOR ──────────────────────────── -->
            <Grid Padding="28,0,28,20"
                  ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0"
                       Text="CARDS"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#2D3748"
                       CharacterSpacing="2"
                       VerticalOptions="Center"/>
                <BoxView Grid.Column="1"
                         HeightRequest="1"
                         BackgroundColor="#1A2233"
                         Margin="10,0"
                         VerticalOptions="Center"/>
            </Grid>

            <!-- ── LISTA DE CARDS ─────────────────────── -->
            <CollectionView ItemsSource="{Binding Cards}"
                            Margin="28,0,28,40"
                            SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="10" Margin="0,40,0,0">
                        <Label Text="—"
                               FontSize="32"
                               TextColor="#2D3748"
                               HorizontalOptions="Center"/>
                        <Label Text="Nenhum card ainda"
                               FontSize="15"
                               TextColor="#4A5568"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                BackgroundColor="#0F1623"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#1A2233"
                                StrokeThickness="1"
                                Padding="20,18">
                            <Grid ColumnDefinitions="4,*" ColumnSpacing="14">

                                <!-- Barra lateral verde -->
                                <BoxView Grid.Column="0"
                                         BackgroundColor="#00E5A0"
                                         CornerRadius="2"
                                         WidthRequest="4"/>

                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="{Binding Pergunta}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#E2E8F0"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"/>
                                    <Label Text="{Binding Resposta}"
                                           FontSize="13"
                                           TextColor="#4A5568"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"/>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
